# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# May be overriden by cross-env!
NODE_ENV=development

# === web/ + fastify/ (separate client/server) ===
PUBLIC_SERVER_PORT=2022
PUBLIC_SERVER_URL=http://localhost:2022
PUBLIC_SERVER_API_PATH=/api
# Frontend URL, used to configure trusted origin (cors)
PUBLIC_CLIENT_URL=http://localhost:3035

# Rate limiting
RATE_LIMIT_MAX=1000
# 10 minutes (1000 * 60 * 10)
RATE_LIMIT_WINDOW=600000

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3035,http://localhost:3046/,http://localhost:4173

# Set this if you want to run or deploy your app at a base URL. This is
# usually required for deploying a repository to Github/Gitlab pages.
# PUBLIC_BASE_PATH=/repository-name/
#PUBLIC_BASE_PATH=/

# Database
DATABASE_URL=mysql://root:secret@localhost:3306/db-name

# BetterAuth
# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET=dev-32-character-secret-key-here-safe
AUTH_GOOGLE_CLIENT_ID=google-client-id
AUTH_GOOGLE_CLIENT_SECRET=google-client-secret
AUTH_DISCORD_CLIENT_ID=doscord-client-id
AUTH_DISCORD_CLIENT_SECRET=doscord-client-secret
