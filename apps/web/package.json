{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env vite --configLoader runner dev",
    "build": "tsc -b && pnpm with-env vite --configLoader runner build",
    "preview": "vite --configLoader runner preview",
    "with-env": "dotenv -e ../../.env --",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --project tsconfig.app.json && tsc --noEmit --project tsconfig.node.json",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@t3-oss/env-core": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-store": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@workspace/api": "workspace:*",
    "@workspace/auth": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/validators": "workspace:*",
    "lucide-react": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "catalog:",
    "url-join": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-form-devtools": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-legacy": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/prettier-config": "workspace:*",
    "@workspace/tailwind-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "browser-sync": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-browser-sync": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@workspace/prettier-config"
}
